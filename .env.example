# ── App ─────────────────────────────────────────────────────────
NODE_ENV=development
PORT=3000

# ── PostgreSQL 16 ─────────────────────────────────────────────────
# app_runtime/audit_writer/etc. son roles NOLOGIN (000_extensions.sql) —
# no se puede conectar directamente como ellos. DB_USERNAME debe ser un
# rol LOGIN que sea miembro de app_runtime (ver
# src/database/sql/local-dev-login-role.sql y el README).
DB_HOST=localhost
DB_PORT=5432
DB_USERNAME=medtravel_app
DB_PASSWORD=change-me
DB_DATABASE=medtravel
DB_SSL=false

# Rol usado solo para correr migraciones (000_extensions..009_tests),
# necesita permisos de owner/DDL. Nunca usar este rol en runtime.
DB_MIGRATION_USERNAME=migration_owner
DB_MIGRATION_PASSWORD=change-me

# Clave usada por core.encrypt_pii/decrypt_pii (SET a nivel de conexión,
# nunca por request). Debe coincidir con la infraestructura del schema.
DB_ENCRYPTION_KEY=change-me

# ── Redis / BullMQ ────────────────────────────────────────────────
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# ── Auth (JWT) ────────────────────────────────────────────────────
JWT_SECRET=change-me
JWT_ACCESS_TTL=15m
JWT_REFRESH_TTL=7d

# ── CORS / Socket.io ──────────────────────────────────────────────
CORS_ORIGIN=http://localhost:5173
